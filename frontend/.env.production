# Browser calls same-origin /api and /hubs by default to avoid CORS preflight OPTIONS.
# App Platform ingress must route /api and /hubs to the API service with preserve_path_prefix.
# Set VITE_FORCE_CROSS_ORIGIN_API=true + VITE_API_BASE_URL only when the API must live on another origin.
# VITE_FORCE_CROSS_ORIGIN_API=true
# VITE_API_BASE_URL=https://your-api-host.example.com
