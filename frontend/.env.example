# =============================================================================
# Trader SPA (Vite) — environment variable catalog
# =============================================================================
# Only VITE_* variables are exposed to browser code (import.meta.env).
#
# Local dev: copy to .env.development or .env.local (gitignored).
# Production build: set before `npm run build` (CI / Docker build-args).
#
# Default: same-origin /api and /hubs — Vite dev proxy or nginx/App Platform ingress.
# =============================================================================

# Dev server port (default 5173)
VITE_DEV_SERVER_PORT=5173

# --- Same-origin (default — recommended) ----------------------------------------
# Leave unset: browser uses relative /api and /hubs (no CORS preflight).

# --- Cross-origin API (optional; both required together) ------------------------
# VITE_FORCE_CROSS_ORIGIN_API=true
# VITE_API_BASE_URL=http://localhost:5232

# --- Vite dev proxy (when using same-origin /api) -------------------------------
# Target for /api and /hubs proxy; defaults to http://localhost:5232
# VITE_API_PROXY_TARGET=http://localhost:5232

# --- Docker nginx runtime (not Vite; web container env) -------------------------
# API_UPSTREAM=http://api:8080
