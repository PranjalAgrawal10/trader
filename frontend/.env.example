# Browser calls same-origin /api by default to avoid CORS preflight OPTIONS.
# Set these only when you intentionally need a different API origin.
# VITE_FORCE_CROSS_ORIGIN_API=true
# VITE_API_BASE_URL=http://localhost:5232
VITE_DEV_SERVER_PORT=5173
# Optional override for Vite dev proxy only:
# VITE_API_PROXY_TARGET=http://localhost:5232
