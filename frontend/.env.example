# =============================================================================
# Trader SPA (Vite) — environment variable catalog
# =============================================================================
# Only variables prefixed with VITE_ are exposed to browser code (import.meta.env).
#
# Local dev: copy to .env.development or .env.local (gitignored).
# Production build: set as Docker build-args or CI env before `npm run build`.
#
# Default: same-origin /api and /hubs (Vite dev proxy or nginx in Docker) — no CORS preflight.
# =============================================================================

# Vite dev server port (default 5173)
VITE_DEV_SERVER_PORT=5173

# --- Same-origin (recommended) -------------------------------------------------
# Leave VITE_FORCE_CROSS_ORIGIN_API unset/false and VITE_API_BASE_URL empty.
# Dev: Vite proxies /api and /hubs to the API (see vite.config.ts).

# --- Split-host / cross-origin API (optional escape hatch) ---------------------
# Both must be set together for the SPA to call a different API origin.
# VITE_FORCE_CROSS_ORIGIN_API=true
# VITE_API_BASE_URL=http://localhost:5232

# --- Vite dev proxy target only ------------------------------------------------
# Used when the browser uses relative /api (default). Falls back to VITE_API_BASE_URL then http://localhost:5232.
# VITE_API_PROXY_TARGET=http://localhost:5232

# --- Docker / nginx (container runtime — not Vite; set on web service) -----------
# API_UPSTREAM=http://api:8080
# (See frontend/Dockerfile and nginx.conf.template; App Platform: API component private URL.)

# --- Docker build-args (frontend/Dockerfile) -----------------------------------
# ARG/ENV VITE_FORCE_CROSS_ORIGIN_API=
# ARG/ENV VITE_API_BASE_URL=
# Leave empty for same-origin nginx proxy to API.
