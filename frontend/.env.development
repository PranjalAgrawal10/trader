# Browser calls same-origin /api to avoid CORS preflight OPTIONS.
# Vite proxies /api and /hubs to the API target below.
# Set VITE_FORCE_CROSS_ORIGIN_API=true + VITE_API_BASE_URL only when you intentionally need cross-origin API calls.
# VITE_API_BASE_URL=http://localhost:5232
# Dev server (optional)
VITE_DEV_SERVER_PORT=5173
# Vite proxy target when using relative /api (defaults to VITE_API_BASE_URL then http://localhost:5232)
# VITE_API_PROXY_TARGET=http://localhost:5232
