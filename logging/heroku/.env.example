# Heroku `kibana` app — OpenSearch Dashboards + HTML login proxy (logging/heroku/).
# Set with: heroku config:set KEY=value -a kibana
# Do not commit real secrets.

# Required — Trader Logs sign-in at /__auth/login (not OpenSearch docs admin/admin)
DASHBOARDS_BASIC_AUTH_USER=your-username
DASHBOARDS_BASIC_AUTH_PASSWORD=change-me

# Optional — HMAC secret for session cookie (defaults derived from user:pass if unset)
# DASHBOARDS_SESSION_SECRET=

# Cluster URL (Bonsai add-on sets BONSAI_URL). Entrypoint prefers OPENSEARCH_HOSTS,
# then ELASTICSEARCH_HOSTS, then BONSAI_URL.
# BONSAI_URL=https://USER:PASS@YOUR-CLUSTER.bonsaisearch.net:443
# ELASTICSEARCH_HOSTS=${BONSAI_URL}
# OPENSEARCH_HOSTS=${BONSAI_URL}

# OSD saved-object index (avoid colliding with other tenants on shared Bonsai)
# OPENSEARCH_DASHBOARDS_INDEX=.trader_osd

# Leave true — securityDashboards is removed; HTML proxy owns auth
DISABLE_SECURITY_DASHBOARDS_PLUGIN=true
