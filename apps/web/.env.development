# Public API origin (browser). Match Kestrel / Docker mapped port for Trader.Api.
VITE_API_BASE_URL=http://localhost:5232
# Dev server (optional)
VITE_DEV_SERVER_PORT=5173
# Vite proxy target when using relative /api (defaults to VITE_API_BASE_URL then http://localhost:5232)
# VITE_API_PROXY_TARGET=http://localhost:5232
