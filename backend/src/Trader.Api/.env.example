# API local config — used only when ASPNETCORE_ENVIRONMENT=Development (DotEnvBootstrap).
# Production: set real values as process environment variables on the host; .env files are NOT loaded.
# Copy to .env.development or use .env.development.local (gitignored). ASP.NET nested keys use __ in .env files.

Database__Provider=MySQL

# Live tick → 1m candles into HistoricalCandles (MySQL upsert). Set false for InMemory-only runs.
# LiveCandles__Enabled=true

# MySQL — discrete fields only (see README). Copy into .env.development / .env.development.local.
Database__Host=localhost
Database__Port=3306
Database__Name=trader
Database__Username=root
Database__Password=YOUR_PASSWORD
# Same binding via common Docker/host env names (optional alternative to Database__*):
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=trader
# MYSQL_USER=root
# MYSQL_PASSWORD=YOUR_PASSWORD
# Managed MySQL (e.g. DigitalOcean) — TLS + non-default port:
# Database__Host=your-cluster.db.ondigitalocean.com
# Database__Port=25060
# Database__Name=defaultdb
# Database__Username=doadmin
# Database__Password=YOUR_PASSWORD
# Database__SslMode=Required

Jwt__Issuer=Trader
Jwt__Audience=TraderClients
Jwt__Key=REPLACE_WITH_MINIMUM_32_CHARACTER_SECRET
Jwt__ExpiresHours=12

# Max time (minutes, 1–120) the user may stay on the authenticator step after a successful password check.
Auth__TwoFactorLoginTicketLifetimeMinutes=30
Auth__EmailVerificationExpiryHours=48
Auth__PasswordResetExpiryHours=48

# SPA origin for links in registration + password-reset emails (no trailing slash).
PublicWeb__FrontendBaseUrl=http://localhost:5173
# PublicWeb__VerifyEmailPath=/verify-email
# PublicWeb__ResetPasswordPath=/reset-password

# Outbound SMTP (e.g. Gmail app password) for email OTP. Off by default until Smtp__IsEnabled=true.
Smtp__IsEnabled=false
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__EnableTls=true
Smtp__User=
Smtp__Password=
Smtp__FromEmail=
# Smtp__FromDisplayName=Trader

# Email OTP tuning (defaults shown)
EmailOtp__ExpiryMinutes=5
EmailOtp__MaxFailedVerifyAttemptsPerChallenge=5

# First origin index (add Cors__Origins__1 for more)
Cors__Origins__0=http://localhost:5173

# Background: resolve + run ML price-direction for every Kite favorite on a timer; EOD email (SMTP: multipart HTML with inline PNG outcome charts via cid + CSV) when enabled.
# When FavoriteMlAutomation__PredictionModelId is omitted/empty, automation runs every GET /api/v1/predictions/price-direction/models engine per bar (comma-separated = subset only).
# Requires active Kite session per user and Smtp__IsEnabled=true for the daily report.
# FavoriteMlAutomation__Enabled=false
# FavoriteMlAutomation__PollIntervalSeconds=60
# FavoriteMlAutomation__PollIntervalMinutes=1
# FavoriteMlAutomation__PredictionIntervalOverride=1m
# Leave PredictionIntervalOverride empty to use saved chart interval (slower cadence on 3m/5m candles).
# Defer new automation rows until at least N seconds after the current ref bar open (intrabar; does not wait for the full candle to close). 0 = off. Values beyond one bar length clamp at runtime.
# FavoriteMlAutomation__MinSecondsAfterBarOpenForAutomation=0
# FavoriteMlAutomation__ReportTimeZoneId=Asia/Kolkata
# FavoriteMlAutomation__ReportLocalHour=23
# FavoriteMlAutomation__ReportLocalMinute=30
# Nightly pause for automation: skip only NEW scheduled predictions; pending rows still resolve. Times in ReportTimeZoneId (Asia/Kolkata = IST).
# FavoriteMlAutomation__QuietHoursEnabled=true
# FavoriteMlAutomation__QuietHoursStartLocalHour=23
# FavoriteMlAutomation__QuietHoursStartLocalMinute=25
# FavoriteMlAutomation__QuietHoursEndLocalHour=8
# FavoriteMlAutomation__QuietHoursEndLocalMinute=0
# FavoriteMlAutomation__PauseAutomationOnWeekends=true
# FavoriteMlAutomation__DefaultChartInterval=5m
# FavoriteMlAutomation__MaxPendingResolutionBatch=2000
# When true (default in appsettings), automation uses three sliding-window votes per bar; stored direction is majority; emails/CSV include best-of-3 extras.
# FavoriteMlAutomation__BestOfThreeEnabled=true
# Comma-separated engine ids subset; omit/empty for all registered engines (not the interactive DefaultModelId).
# FavoriteMlAutomation__PredictionModelId=
#
# Price-direction labeling band (fractional return vs ref close treated as neutral in resolver + persisted labels).
# Example 0.0005 = ±0.05%. Zero matches legacy pure sign(close[t+1]-close[t]) behavior.
# PriceDirectionPrediction__LabelThresholdFraction=0
#
# Optional piecewise-linear isotonic map JSON for ML.NET P(up): {"xs":[0,1],"ys":[...]} under ContentRootPath.
# PriceDirectionPrediction__ScoreCalibrationJsonPath=ml-calibration/pup_cal.json

# Default price-direction engine when the client omits ?model= (must match a registered engine).
# PriceDirectionPrediction__DefaultModelId=mlnet-sdca-logistic-v1

# Zerodha Kite Connect — register RedirectUrl exactly on https://developers.kite.trade/
# Credentials and redirect URL are not read from appsettings; use these keys (or host env vars).
# Put real ApiKey/ApiSecret in .env.development.local (gitignored) so they are not committed.
# RedirectUrl must match this pattern for your API host (default dev API port 5232):
#   http://localhost:5232/api/v1/broker/kite/callback
#
# Preferred production is one public origin: /api and /hubs route to the API, / routes to the SPA.
# That avoids browser CORS preflight OPTIONS for authenticated UI calls.
# Split FE/API production is still possible: Kite Redirect URL + ZerodhaKite__RedirectUrl must use the *API* origin,
# e.g. https://YOUR-API.ondigitalocean.app/api/v1/broker/kite/callback — not the static site. PostLoginRedirectUrl
# = SPA origin + /profile#broker-connection (API callback must still be RedirectUrl on the API host). Split-host SPA builds
# need VITE_FORCE_CROSS_ORIGIN_API=true + VITE_API_BASE_URL = API origin; API needs Cors__Origins__0 = SPA origin.
ZerodhaKite__ApiKey=
ZerodhaKite__ApiSecret=
ZerodhaKite__RedirectUrl=http://localhost:5232/api/v1/broker/kite/callback
# Browser URL after OAuth (SPA); lands on Profile → broker section so the session can refresh status
ZerodhaKite__PostLoginRedirectUrl=http://localhost:5173/profile#broker-connection
