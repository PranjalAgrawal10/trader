# =============================================================================
# Trader.Api — environment variable catalog
# =============================================================================
# Development: DotEnvBootstrap loads .env, .env.development, .env.development.local
# from this directory when ASPNETCORE_ENVIRONMENT=Development.
# Production/Staging: set process env vars on the host — .env files are NOT read.
#
# Nested keys use double underscores: Section__SubSection__Key
# Copy to .env.development.local for machine-specific secrets (gitignored).
# =============================================================================

# --- Host -----------------------------------------------------------------------
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://localhost:5232

# --- Database (MySQL) -----------------------------------------------------------
Database__Provider=MySQL
# Database__ApplyMigrationsOnStartup=true

# Preferred: full URL (Docker, App Platform, managed MySQL)
# DATABASE_URL=mysql://trader:trader@mysql:3306/trader
DATABASE_URL=mysql://root:YOUR_PASSWORD@localhost:3306/trader

# Optional: InMemory (no MySQL)
# Database__Provider=InMemory
# Database__InMemoryDatabase=trader

# Alternative: discrete fields instead of DATABASE_URL (see MySqlConnectionStringResolver for MYSQL_*/DB_* aliases)
# Database__Host=localhost
# Database__Port=3306
# Database__Name=trader
# Database__Username=root
# Database__Password=YOUR_PASSWORD
# Database__SslMode=Required

# Compose MySQL on host port 3307: use port 3307 in DATABASE_URL when API runs on host.

# --- JWT (required) -------------------------------------------------------------
Jwt__Issuer=Trader
Jwt__Audience=TraderClients
Jwt__Key=REPLACE_WITH_MINIMUM_32_CHARACTER_SECRET
Jwt__ExpiresHours=12

# --- Auth -----------------------------------------------------------------------
# Auth__TwoFactorLoginTicketLifetimeMinutes=30
# Auth__EmailVerificationExpiryHours=48
# Auth__PasswordResetExpiryHours=48

# --- Public SPA URLs (email links) ----------------------------------------------
PublicWeb__FrontendBaseUrl=http://localhost:5173
# PublicWeb__VerifyEmailPath=/verify-email
# PublicWeb__ResetPasswordPath=/reset-password

# --- CORS (required; add Cors__Origins__1, __2, … for more origins) -------------
Cors__Origins__0=http://localhost:5173
# Cors__Origins__1=http://localhost:8080

# --- SMTP (verification, reset, 2FA email OTP, ML EOD reports) ------------------
Smtp__IsEnabled=false
# Smtp__Host=smtp.gmail.com
# Smtp__Port=587
# Smtp__EnableTls=true
# Smtp__User=
# Smtp__Password=
# Smtp__FromEmail=
# Smtp__FromDisplayName=Trader

# --- Email OTP (2FA) ------------------------------------------------------------
# EmailOtp__ExpiryMinutes=5
# EmailOtp__MaxFailedVerifyAttemptsPerChallenge=5

# --- Data Protection (encrypt broker tokens, TOTP; persist in Production) -------
# DataProtection__KeyRingPath=/var/lib/trader/dataprotection

# --- Swagger (Development enables automatically) ----------------------------------
# Swagger__Enabled=false

# --- Live 1m OHLC from ticks ----------------------------------------------------
# LiveCandles__Enabled=true

# --- Zerodha Kite (secrets in .env.development.local; not in appsettings.json) --
# Register RedirectUrl exactly on https://developers.kite.trade/
ZerodhaKite__ApiKey=
ZerodhaKite__ApiSecret=
ZerodhaKite__RedirectUrl=http://localhost:5232/api/v1/broker/kite/callback
ZerodhaKite__PostLoginRedirectUrl=http://localhost:5173/profile#broker-connection

# --- Groww -----------------------------------------------------------------------
# Groww__ApiBaseUrl=https://api.groww.in/v1/

# --- Demo auto-trade (hypothetical P&L; no broker orders) -----------------------
# DemoAutoTrade__Charges__Enabled=true
# DemoAutoTrade__Charges__RoundTripFlatInrPerLeg=40
# DemoAutoTrade__Charges__RoundTripTurnoverBps=2

# --- Price-direction ML -------------------------------------------------------
# PriceDirectionPrediction__DefaultModelId=mlnet-sdca-logistic-v1
# PriceDirectionPrediction__LabelThresholdFraction=0
# PriceDirectionPrediction__ScoreCalibrationJsonPath=ml-calibration/pup_cal.json
# PriceDirectionPrediction__LabelThresholdFractionByInterval__1m=0.0004
# PriceDirectionPrediction__MinTrainingRowsByInterval__1m=80
# PriceDirectionPrediction__NeutralConfidenceFloorByInterval__1m=57

# --- Favorite ML automation (background job; needs Kite session + SMTP for EOD) -
# FavoriteMlAutomation__Enabled=true
# FavoriteMlAutomation__PollIntervalSeconds=1
# FavoriteMlAutomation__PollIntervalMinutes=1
# FavoriteMlAutomation__PredictionIntervalOverride=1m
# FavoriteMlAutomation__MinSecondsAfterBarOpenForAutomation=0
# FavoriteMlAutomation__ReportTimeZoneId=Asia/Kolkata
# FavoriteMlAutomation__ReportLocalHour=23
# FavoriteMlAutomation__ReportLocalMinute=30
# FavoriteMlAutomation__BestOfThreeEnabled=true
# FavoriteMlAutomation__QuietHoursEnabled=true
# FavoriteMlAutomation__PauseAutomationOnWeekends=true
# FavoriteMlAutomation__TradingSessionRestrictionsEnabled=true
