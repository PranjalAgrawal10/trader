# =============================================================================
# Trader.Api — environment variable catalog (Development .env template)
# =============================================================================
# Loaded only when ASPNETCORE_ENVIRONMENT=Development (DotEnvBootstrap merges
# .env, .env.development, .env.development.local from this project directory).
# Production/Staging: set process env vars on the host — .env files are NOT read.
#
# ASP.NET nested keys use double underscores: Section__SubSection__Key
# Copy to .env.development or .env.development.local (gitignored for secrets).
# =============================================================================

# --- Host / ASP.NET Core -------------------------------------------------------
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://localhost:5232

# --- Database ------------------------------------------------------------------
Database__Provider=MySQL
# Auto-run EF Core migrations on API startup (default true in appsettings.json).
# Database__ApplyMigrationsOnStartup=true

# Optional: Database__Provider=InMemory (no MySQL; integration-style local runs)
# Database__InMemoryDatabase=trader

# MySQL — recommended: DATABASE_URL (production, Docker, App Platform linked DB)
# DATABASE_URL=mysql://root:YOUR_PASSWORD@localhost:3306/trader
# DATABASE_URL=mysql://doadmin:SECRET@HOST:25060/defaultdb?ssl-mode=Required

# MySQL — alternative: discrete fields (local dev). See MySqlConnectionStringResolver.
Database__Host=localhost
Database__Port=3306
Database__Name=trader
Database__Username=root
Database__Password=YOUR_PASSWORD
# Database__UserId=root
# Database__SslMode=Required

# Equivalent env aliases (optional instead of Database__*):
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=trader
# MYSQL_USER=root
# MYSQL_PASSWORD=YOUR_PASSWORD
# MYSQL_PWD=YOUR_PASSWORD
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_NAME=trader
# DATABASE_USER=root
# DATABASE_PASSWORD=YOUR_PASSWORD
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=trader
# DB_DATABASE=trader
# DB_USER=root
# DB_USERNAME=root
# DB_PASSWORD=YOUR_PASSWORD
# MYSQL_SSL_MODE=Required
# DATABASE_SSL_MODE=Required

# Docker Compose MySQL on host port 3307: Database__Port=3307 (api service uses mysql:3306).

# --- JWT (required for real runs) --------------------------------------------
Jwt__Issuer=Trader
Jwt__Audience=TraderClients
Jwt__Key=REPLACE_WITH_MINIMUM_32_CHARACTER_SECRET
Jwt__ExpiresHours=12

# --- Auth (registration, 2FA ticket, reset links) ----------------------------
Auth__TwoFactorLoginTicketLifetimeMinutes=30
Auth__EmailVerificationExpiryHours=48
Auth__PasswordResetExpiryHours=48

# --- Public SPA URLs (email links) ---------------------------------------------
PublicWeb__FrontendBaseUrl=http://localhost:5173
# PublicWeb__VerifyEmailPath=/verify-email
# PublicWeb__ResetPasswordPath=/reset-password

# --- SMTP (email verification, password reset, 2FA email OTP, ML EOD reports) --
Smtp__IsEnabled=false
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__EnableTls=true
Smtp__User=
Smtp__Password=
Smtp__FromEmail=
# Smtp__FromDisplayName=Trader

# --- Email OTP (2FA) -----------------------------------------------------------
EmailOtp__ExpiryMinutes=5
EmailOtp__MaxFailedVerifyAttemptsPerChallenge=5

# --- CORS (SPA origins; add Cors__Origins__1, __2, … for more) -----------------
Cors__Origins__0=http://localhost:5173
# Cors__Origins__1=http://127.0.0.1:5173
# Cors__Origins__2=http://localhost:8080

# --- Data Protection (encrypt broker tokens, TOTP secrets) ---------------------
# Persist key ring in Production so redeploys do not invalidate encrypted DB fields.
# DataProtection__KeyRingPath=/var/lib/trader/dataprotection

# --- Swagger -------------------------------------------------------------------
# Development enables Swagger automatically. For other environments:
# Swagger__Enabled=false

# --- Live market ticks → 1m OHLC in HistoricalCandles -------------------------
# LiveCandles__Enabled=true

# --- Allowed hosts (optional; default * in appsettings.json) -------------------
# AllowedHosts=*

# --- Logging (optional overrides; see appsettings*.json for Serilog sinks) -----
# Logging__LogLevel__Default=Information
# Logging__LogLevel__Microsoft.AspNetCore=Warning
# Logging__LogLevel__Microsoft.AspNetCore.Authentication=Information
# Logging__LogLevel__Microsoft.AspNetCore.Authentication.JwtBearer=Information
# Logging__LogLevel__Trader.Api.JwtBearer=Warning

# --- Zerodha Kite Connect (not in committed appsettings; use env / .env.local) -
# Register RedirectUrl exactly on https://developers.kite.trade/
# Dev default: http://localhost:5232/api/v1/broker/kite/callback
ZerodhaKite__ApiKey=
ZerodhaKite__ApiSecret=
ZerodhaKite__RedirectUrl=http://localhost:5232/api/v1/broker/kite/callback
ZerodhaKite__PostLoginRedirectUrl=http://localhost:5173/profile#broker-connection

# --- Groww Trading API ---------------------------------------------------------
# Users connect from Profile with daily token or apiKey + secret/totp (stored encrypted).
# Groww__ApiBaseUrl=https://api.groww.in/v1/

# --- Demo auto-trade (hypothetical P&L only; no broker orders) -----------------
# DemoAutoTrade__Charges__Enabled=true
# DemoAutoTrade__Charges__RoundTripFlatInrPerLeg=40
# DemoAutoTrade__Charges__RoundTripTurnoverBps=2

# --- Price-direction ML (interactive API + engines) ----------------------------
# PriceDirectionPrediction__DefaultModelId=mlnet-sdca-logistic-v1
# PriceDirectionPrediction__DefaultModelId=mlnet-fno-multi-horizon-v1
# PriceDirectionPrediction__LabelThresholdFraction=0
# PriceDirectionPrediction__ScoreCalibrationJsonPath=ml-calibration/pup_cal.json
# PriceDirectionPrediction__ScoreCalibrationJsonPathByInterval__1m=ml-calibration/pup_1m.json
# PriceDirectionPrediction__ScoreCalibrationJsonPathByInterval__5m=ml-calibration/pup_5m.json
# PriceDirectionPrediction__ScoreCalibrationJsonPathByInterval__15m=ml-calibration/pup_15m.json
# PriceDirectionPrediction__LabelThresholdFractionByInterval__1m=0.0004
# PriceDirectionPrediction__LabelThresholdFractionByInterval__5m=0.0008
# PriceDirectionPrediction__LabelThresholdFractionByInterval__15m=0.0012
# PriceDirectionPrediction__MinTrainingRowsByInterval__1m=80
# PriceDirectionPrediction__MinTrainingRowsByInterval__5m=64
# PriceDirectionPrediction__MinTrainingRowsByInterval__15m=56
# PriceDirectionPrediction__NeutralConfidenceFloorByInterval__1m=57
# PriceDirectionPrediction__NeutralConfidenceFloorByInterval__5m=56
# PriceDirectionPrediction__NeutralConfidenceFloorByInterval__15m=55

# --- Favorite ML automation (background job; requires Kite session per user) ---
# When FavoriteMlAutomation__PredictionModelId is omitted/empty, every registered engine runs per bar (comma-separated = subset).
# Requires Smtp__IsEnabled=true for daily EOD email reports.
# FavoriteMlAutomation__Enabled=true
# FavoriteMlAutomation__PollIntervalSeconds=1
# FavoriteMlAutomation__PollIntervalMinutes=1
# FavoriteMlAutomation__PredictionIntervalOverride=1m
# FavoriteMlAutomation__MinSecondsAfterBarOpenForAutomation=0
# FavoriteMlAutomation__ReportTimeZoneId=Asia/Kolkata
# FavoriteMlAutomation__ReportLocalHour=23
# FavoriteMlAutomation__ReportLocalMinute=30
# FavoriteMlAutomation__DefaultChartInterval=5m
# FavoriteMlAutomation__MaxPendingResolutionBatch=2000
# FavoriteMlAutomation__BestOfThreeEnabled=true
# FavoriteMlAutomation__PredictionModelId=
# FavoriteMlAutomation__QuietHoursEnabled=true
# FavoriteMlAutomation__QuietHoursStartLocalHour=23
# FavoriteMlAutomation__QuietHoursStartLocalMinute=25
# FavoriteMlAutomation__QuietHoursEndLocalHour=8
# FavoriteMlAutomation__QuietHoursEndLocalMinute=0
# FavoriteMlAutomation__PauseAutomationOnWeekends=true
# FavoriteMlAutomation__TradingSessionRestrictionsEnabled=true
# FavoriteMlAutomation__TradingSessionStartLocalHour=9
# FavoriteMlAutomation__TradingSessionStartLocalMinute=15
# FavoriteMlAutomation__TradingSessionEndLocalHour=15
# FavoriteMlAutomation__TradingSessionEndLocalMinute=30
# FavoriteMlAutomation__SkipTradingSessionForMcxFavorites=true
# FavoriteMlAutomation__IstMinuteBoundaryAlignmentEnabled=false
# FavoriteMlAutomation__IstMinuteBoundarySeconds=22
