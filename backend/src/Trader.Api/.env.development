# Trader.Api — shared development defaults (no secrets).
# Put passwords and API keys in .env.development.local (gitignored).
Database__Provider=MySQL
DATABASE_URL=mysql://root:YOUR_PASSWORD@localhost:3306/trader
Jwt__Issuer=Trader
Jwt__Audience=TraderClients
Jwt__Key=CHANGE_ME_DEVELOPMENT_KEY_MIN_32_CHARS!!
Jwt__ExpiresHours=12
Cors__Origins__0=http://localhost:5173
PublicWeb__FrontendBaseUrl=http://localhost:5173
