{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "MySQL",
    "ApplyMigrationsOnStartup": true,
    "Host": "",
    "Port": "3306",
    "Name": "",
    "Username": "",
    "UserId": "",
    "Password": "",
    "SslMode": ""
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "Key": "",
    "ExpiresHours": 12
  },
  "Auth": {
    "TwoFactorLoginTicketLifetimeMinutes": 30,
    "EmailVerificationExpiryHours": 48,
    "PasswordResetExpiryHours": 48
  },
  "PublicWeb": {
    "FrontendBaseUrl": "",
    "VerifyEmailPath": "/verify-email",
    "ResetPasswordPath": "/reset-password"
  },
  "Cors": {
    "Origins": []
  },
  "LiveCandles": {
    "Enabled": true
  },
  "PriceDirectionPrediction": {
    "DefaultModelId": "mlnet-sdca-logistic-v1",
    "LabelThresholdFraction": 0.0,
    "LabelThresholdFractionByInterval": {
      "1m": 0.0004,
      "5m": 0.0008,
      "15m": 0.0012
    },
    "MinTrainingRowsByInterval": {
      "1m": 80,
      "5m": 64,
      "15m": 56
    },
    "NeutralConfidenceFloorByInterval": {
      "1m": 57,
      "5m": 56,
      "15m": 55
    }
  },
  "DemoAutoTrade": {
    "Charges": {
      "Enabled": true,
      "RoundTripFlatInrPerLeg": 40,
      "RoundTripTurnoverBps": 2
    }
  },
  "NiftyOpenAutoTrade": {
    "Enabled": true,
    "PollIntervalSeconds": 5,
    "TimeZoneId": "Asia/Kolkata",
    "FireLocalHour": 9,
    "FireLocalMinute": 15,
    "FireWindowSeconds": 120,
    "PauseOnWeekends": true,
    "DefaultStopLossPoints": 5,
    "DefaultTargetPoints": 5,
    "TrailEndLocalHour": 15,
    "TrailEndLocalMinute": 25,
    "DefaultMaxLots": 10,
    "AbsoluteMaxLots": 10,
    "BalanceUtilizationFraction": 1,
    "MaxStrikeStepsAwayFromAtm": 3,
    "Product": "MIS",
    "SpotSearchQuery": "NIFTY 50",
    "OptionSearchQuery": "NIFTY",
    "PreferredSpotExchange": "NSE",
    "OrderTag": "nifty-opening-atm"
  },
  "FavoriteMlAutomation": {
    "Enabled": true,
    "PollIntervalSeconds": 1,
    "PollIntervalMinutes": 1,
    "PredictionIntervalOverride": "1m",
    "ReportTimeZoneId": "Asia/Kolkata",
    "ReportLocalHour": 23,
    "ReportLocalMinute": 30,
    "QuietHoursEnabled": true,
    "QuietHoursStartLocalHour": 23,
    "QuietHoursStartLocalMinute": 25,
    "QuietHoursEndLocalHour": 8,
    "QuietHoursEndLocalMinute": 0,
    "PauseAutomationOnWeekends": true,
    "TradingSessionRestrictionsEnabled": true,
    "TradingSessionStartLocalHour": 9,
    "TradingSessionStartLocalMinute": 15,
    "TradingSessionEndLocalHour": 15,
    "TradingSessionEndLocalMinute": 30,
    "SkipTradingSessionForMcxFavorites": true,
    "IstMinuteBoundaryAlignmentEnabled": false,
    "IstMinuteBoundarySeconds": 22,
    "DefaultChartInterval": "5m",
    "MaxPendingResolutionBatch": 2000,
    "BestOfThreeEnabled": true,
    "MinSecondsAfterBarOpenForAutomation": 0
  }
}
