{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Database": {
    "Provider": "InMemory",
    "InMemoryDatabase": "integration-tests"
  },
  "Jwt": {
    "Issuer": "IntegrationTests",
    "Audience": "IntegrationTests",
    "Key": "IntegrationTesting_Secret_Key_At_Least_32_Chars!",
    "ExpiresHours": 12
  },
  "Cors": {
    "Origins": ["http://localhost"]
  },
  "LiveCandles": {
    "Enabled": false
  },
  "FavoriteMlAutomation": {
    "Enabled": false,
    "QuietHoursEnabled": false,
    "PauseAutomationOnWeekends": false
  }
}
