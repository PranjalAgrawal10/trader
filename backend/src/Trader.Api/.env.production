# --- Required (typical production) ---------------------------------------------
Database__Provider=MySQL
# From DigitalOcean Managed MySQL → Connection details (encrypt on the host):
# mysql://doadmin:YOUR_PASSWORD@YOUR_HOST.db.ondigitalocean.com:25060/defaultdb?ssl-mode=Required
DATABASE_URL=mysql://doadmin:YOUR_PASSWORD@YOUR_HOST.db.ondigitalocean.com:25060/defaultdb?ssl-mode=Required
