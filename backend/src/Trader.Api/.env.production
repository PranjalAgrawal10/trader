# Trader.Api — production template (set real values on the host; Production does not load .env).
# DigitalOcean Managed MySQL: non-standard port (often 25060) + Database__SslMode=Required.
Database__Provider=MySQL
Database__Host=YOUR_MANAGED_MYSQL_HOST
Database__Port=25060
Database__Name=defaultdb
Database__Username=doadmin
Database__Password=YOUR_DO_PASSWORD
Database__SslMode=Required
# Set JWT and CORS on the host (App Platform env / secrets).
Jwt__ExpiresHours=12
